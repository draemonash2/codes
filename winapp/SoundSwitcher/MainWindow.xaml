<Window x:Class="SoundSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SoundSwitcher.ViewModels"
        xmlns:models="clr-namespace:SoundSwitcher.Models"
        xmlns:local="clr-namespace:SoundSwitcher"
        Title="Sound Switcher"
        Width="600" Height="520"
        MinWidth="420" MinHeight="360"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#02000000"
        Topmost="False"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1A1C22"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#22252E"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2E3140"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F8EF7"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#3DCA7A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F2F7"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8890A4"/>

        <local:BoolToWeightConverter x:Key="BoolToWeight"/>
        <local:BoolToAccentBrushConverter x:Key="BoolToAccent"/>
        <local:BatteryColorConverter x:Key="BatteryColor"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:DeviceKindToIconConverter x:Key="KindToIcon"/>
        <local:BatteryArcPointConverter x:Key="ArcPoint"/>
        <local:BatteryIsLargeArcConverter x:Key="ArcIsLarge"/>

        <!-- Icon button template -->
        <ControlTemplate x:Key="IconButtonTemplate" TargetType="Button">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="6">
                <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Background" Value="#2E3140"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Device card -->
        <DataTemplate x:Key="DeviceCardTemplate" DataType="{x:Type models:AudioDevice}">
            <Button Command="{Binding DataContext.SetDefaultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Opacity="{Binding OpacityValue}"
                    Width="124"
                    Cursor="Hand"
                    ToolTip="{Binding Name}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="12"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource BorderBrush2}"
                                Padding="0,14,0,14">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Card" Property="Background" Value="#282B36"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

                <StackPanel Width="100" HorizontalAlignment="Center">
                    <!-- Icon + battery ring -->
                    <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,7">

                        <!-- Battery arc -->
                        <Canvas Width="64" Height="64">
                            <Canvas.Visibility>
                                <Binding Path="HasBattery" Converter="{StaticResource BoolToVis}"/>
                            </Canvas.Visibility>
                            <!-- Track ring (dim) -->
                            <Ellipse Canvas.Left="3" Canvas.Top="3" Width="58" Height="58"
                                     Stroke="#2E3140" StrokeThickness="3" Fill="Transparent"/>
                            <!-- Battery arc -->
                            <Path Stroke="{Binding BatteryPercent, Converter={StaticResource BatteryColor}}"
                                  StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="32,3" IsClosed="False">
                                            <ArcSegment
                                                Point="{Binding BatteryPercent, Converter={StaticResource ArcPoint}}"
                                                Size="29,29"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="{Binding BatteryPercent, Converter={StaticResource ArcIsLarge}}"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>
                        </Canvas>

                        <!-- Circle bg -->
                        <Ellipse Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#2E3245" Offset="0"/>
                                    <GradientStop Color="#1A1D28" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Device kind icon -->
                        <TextBlock Text="{Binding Kind, Converter={StaticResource KindToIcon}}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{Binding IsDefault, Converter={StaticResource BoolToAccent}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Default blue dot -->
                        <Ellipse Width="8" Height="8"
                                 Fill="#4F8EF7"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                 Margin="0,0,5,5">
                            <Ellipse.Visibility>
                                <Binding Path="IsDefault" Converter="{StaticResource BoolToVis}"/>
                            </Ellipse.Visibility>
                        </Ellipse>

                        <!-- Disconnected X badge -->
                        <Border Width="16" Height="16" CornerRadius="8"
                                Background="#CC3333"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,4,4,0">
                            <Border.Visibility>
                                <Binding Path="IsConnected" Converter="{StaticResource BoolToVis}" ConverterParameter="invert"/>
                            </Border.Visibility>
                            <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="8" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Battery % -->
                    <TextBlock Text="{Binding BatteryPercent, StringFormat={}{0}%}"
                               FontSize="11"
                               Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryColor}}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4">
                        <TextBlock.Visibility>
                            <Binding Path="HasBattery" Converter="{StaticResource BoolToVis}"/>
                        </TextBlock.Visibility>
                    </TextBlock>

                    <!-- Device name -->
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               FontWeight="{Binding IsDefault, Converter={StaticResource BoolToWeight}}"
                               Foreground="{Binding IsDefault, Converter={StaticResource BoolToAccent}}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="100"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="12" CornerRadius="16" Background="{StaticResource BgBrush}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="6" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar (draggable) -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="20,12,20,12"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE995;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="17" Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Sound Switcher" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1" Template="{StaticResource IconButtonTemplate}"
                            Command="{Binding RefreshCommand}" Margin="0,0,4,0"
                            ToolTip="Refresh" Cursor="Hand">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Grid.Column="2" Template="{StaticResource IconButtonTemplate}"
                            Click="CloseButton_Click" Cursor="Hand" ToolTip="Close">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,16,20,20">
                <!-- Divider -->
                <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="0,0,0,16"/>

                <!-- Playback -->
                <TextBlock Text="PLAYBACK" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,18">
                    <ItemsControl ItemsSource="{Binding PlaybackDevices}" ItemTemplate="{StaticResource DeviceCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Recording -->
                <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="0,0,0,16"/>
                <TextBlock Text="RECORDING" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding RecordingDevices}" ItemTemplate="{StaticResource DeviceCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
