<Window x:Class="SoundSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SoundSwitcher.ViewModels"
        xmlns:models="clr-namespace:SoundSwitcher.Models"
        xmlns:local="clr-namespace:SoundSwitcher"
        Title="Sound Switcher"
        FontFamily="Meiryo UI"
        Width="600" Height="520"
        MinWidth="420" MinHeight="360"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#02000000"
        Topmost="False"
        ShowInTaskbar="False"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1A1C22"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#22252E"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2E3140"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4F8EF7"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#3DCA7A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F2F7"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8890A4"/>

        <local:BoolToWeightConverter x:Key="BoolToWeight"/>
        <local:BoolToAccentBrushConverter x:Key="BoolToAccent"/>
        <local:BatteryColorConverter x:Key="BatteryColor"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BatteryArcPointConverter x:Key="ArcPoint"/>
        <local:BatteryIsLargeArcConverter x:Key="ArcIsLarge"/>

        <!-- Vertical volume slider: a thin rounded track, accent fill from the
             bottom, and a round thumb. Min=0 (bottom) mutes; Max=1 is full. -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="SmallChange" Value="0.02"/>
            <Setter Property="LargeChange" Value="0.1"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Track background -->
                            <Border Width="6" CornerRadius="3"
                                    HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                    Background="{StaticResource BorderBrush2}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <!-- Filled portion (below the thumb) -->
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Width="6" CornerRadius="3"
                                                        HorizontalAlignment="Center"
                                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <!-- Empty portion (above the thumb) -->
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Width="6" Background="Transparent"
                                                        HorizontalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14"
                                                         Fill="{StaticResource TextPrimaryBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Device card -->
        <DataTemplate x:Key="DeviceCardTemplate" DataType="{x:Type models:AudioDevice}">
            <Button Command="{Binding DataContext.SetDefaultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Opacity="{Binding OpacityValue}"
                    Width="124"
                    Cursor="Hand"
                    ToolTip="{Binding Name}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                Background="{StaticResource SurfaceBrush}"
                                CornerRadius="12"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource BorderBrush2}"
                                Padding="0,14,0,14">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Card" Property="Background" Value="#282B36"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

                <StackPanel Width="100" HorizontalAlignment="Center">
                    <!-- Icon + battery ring -->
                    <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,7">

                        <!-- Battery arc -->
                        <Canvas Width="64" Height="64">
                            <Canvas.Visibility>
                                <Binding Path="HasBattery" Converter="{StaticResource BoolToVis}"/>
                            </Canvas.Visibility>
                            <!-- Track ring (dim) -->
                            <Ellipse Canvas.Left="3" Canvas.Top="3" Width="58" Height="58"
                                     Stroke="#2E3140" StrokeThickness="3" Fill="Transparent"/>
                            <!-- Battery arc -->
                            <Path Stroke="{Binding BatteryPercent, Converter={StaticResource BatteryColor}}"
                                  StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Fill="Transparent">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="32,3" IsClosed="False">
                                            <ArcSegment
                                                Point="{Binding BatteryPercent, Converter={StaticResource ArcPoint}}"
                                                Size="29,29"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="{Binding BatteryPercent, Converter={StaticResource ArcIsLarge}}"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>
                        </Canvas>

                        <!-- Circle bg -->
                        <Ellipse Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#2E3245" Offset="0"/>
                                    <GradientStop Color="#1A1D28" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Device type icon (varies by form factor) -->
                        <TextBlock Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="{Binding IsDefault, Converter={StaticResource BoolToAccent}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    </Grid>

                    <!-- Device name -->
                    <TextBlock Text="{Binding Name}"
                               FontSize="12"
                               FontWeight="{Binding IsDefault, Converter={StaticResource BoolToWeight}}"
                               Foreground="{Binding IsDefault, Converter={StaticResource BoolToAccent}}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="100"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="12" CornerRadius="16" Background="{StaticResource BgBrush}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="6" Opacity="0.55"/>
        </Border.Effect>

        <!-- Right-click menu replaces the removed title-bar buttons -->
        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="サウンド設定" Click="OpenSoundSettings_Click"/>
                <MenuItem Header="Bluetooth設定" Click="OpenBluetoothSettings_Click"/>
                <MenuItem Header="レベルメーターを表示" IsCheckable="True"
                          IsChecked="{Binding MetersVisible, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="終了" Click="ExitMenu_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <!-- Content (whole window is draggable) -->
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left edge: output / input volume bars. Bottom = mute.
             Each block (icon + slider) is boxed to the matching device card's
             height, so icon + slider together line up with a card. -->
        <!-- Auto width so hiding the meters shrinks this strip and the cards reflow left. -->
        <StackPanel Grid.Column="0" Margin="10,20,0,0" VerticalAlignment="Top">
            <!-- Output -->
            <Grid Height="{Binding ActualHeight, ElementName=PlaybackItems}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="&#xE767;" FontFamily="Segoe MDL2 Assets"
                           FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           ToolTip="出力音量"/>
                <Slider Grid.Row="1" Grid.Column="0" Style="{StaticResource VolumeSlider}"
                        VerticalAlignment="Stretch"
                        Value="{Binding OutputVolume.Volume, Mode=TwoWay}"
                        IsEnabled="{Binding OutputVolume.HasDevice}"
                        HorizontalAlignment="Center"
                        ToolTip="出力音量"/>
                <!-- Output level meter: a solid fill scaled from the bottom (cheaper to
                     re-render each frame than animating a gradient under software rendering). -->
                <Border Grid.Row="1" Grid.Column="1" Width="6" Margin="7,0,0,0"
                        CornerRadius="3" Background="{StaticResource BorderBrush2}"
                        VerticalAlignment="Stretch" ClipToBounds="True" ToolTip="出力レベル"
                        Visibility="{Binding MetersVisible, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource TextSecondaryBrush}" CornerRadius="3"
                            VerticalAlignment="Stretch" RenderTransformOrigin="0.5,1">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="{Binding OutputVolume.Peak}"/>
                        </Border.RenderTransform>
                    </Border>
                </Border>
            </Grid>

            <!-- Input -->
            <Grid Height="{Binding ActualHeight, ElementName=RecordingItems}" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="&#xE720;" FontFamily="Segoe MDL2 Assets"
                           FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"
                           ToolTip="入力音量"/>
                <Slider Grid.Row="1" Grid.Column="0" Style="{StaticResource VolumeSlider}"
                        VerticalAlignment="Stretch"
                        Value="{Binding InputVolume.Volume, Mode=TwoWay}"
                        IsEnabled="{Binding InputVolume.HasDevice}"
                        HorizontalAlignment="Center"
                        ToolTip="入力音量"/>
                <!-- Input level meter: a solid fill scaled from the bottom (cheaper to
                     re-render each frame than animating a gradient under software rendering). -->
                <Border Grid.Row="1" Grid.Column="1" Width="6" Margin="7,0,0,0"
                        CornerRadius="3" Background="{StaticResource BorderBrush2}"
                        VerticalAlignment="Stretch" ClipToBounds="True" ToolTip="入力レベル"
                        Visibility="{Binding MetersVisible, Converter={StaticResource BoolToVis}}">
                    <Border Background="{StaticResource TextSecondaryBrush}" CornerRadius="3"
                            VerticalAlignment="Stretch" RenderTransformOrigin="0.5,1">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleY="{Binding InputVolume.Peak}"/>
                        </Border.RenderTransform>
                    </Border>
                </Border>
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,20,20,20">
                <!-- Playback -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,18">
                    <ItemsControl x:Name="PlaybackItems" ItemsSource="{Binding PlaybackDevices}" ItemTemplate="{StaticResource DeviceCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Recording -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="RecordingItems" ItemsSource="{Binding RecordingDevices}" ItemTemplate="{StaticResource DeviceCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,8,0"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </ScrollViewer>

        </Grid>
    </Border>
</Window>
